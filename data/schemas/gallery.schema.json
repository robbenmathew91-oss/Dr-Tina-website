{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Photo Gallery",
  "type": "object",
  "required": ["gallery"],
  "properties": {
    "gallery": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "url", "caption", "category", "date"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the gallery item"
          },
          "url": {
            "type": "string",
            "description": "Relative path to the image"
          },
          "caption": {
            "type": "string",
            "description": "Descriptive caption (used also as alt text)"
          },
          "category": {
            "type": "string",
            "enum": ["Group", "Research", "Lab Life"],
            "description": "Category of the photo"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Date of photography in YYYY-MM-DD format"
          }
        }
      }
    }
  }
}
