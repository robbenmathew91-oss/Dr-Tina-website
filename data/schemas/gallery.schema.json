{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Photo Gallery",
  "type": "object",
  "required": ["gallery"],
  "properties": {
    "gallery": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "url", "caption", "category", "date"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the gallery item"
          },
          "url": {
            "type": "string",
            "description": "Relative path to the image"
          },
          "caption": {
            "type": "string",
            "description": "Descriptive caption (used also as alt text)"
          },
          "title": {
            "type": "string",
            "description": "Title of the photo"
          },
          "photographer": {
            "type": "string",
            "description": "Photographer credit (optional)"
          },
          "category": {
            "type": "string",
            "enum": [
              "Laboratory",
              "Research",
              "Microscopy",
              "Crystal Growth",
              "Instrumentation",
              "Conferences",
              "Outreach",
              "Awards",
              "Group Photos",
              "Teaching"
            ],
            "description": "Category of the photo"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Date of photography in YYYY-MM-DD format"
          },
          "featured": {
            "type": "boolean",
            "description": "Is this a featured gallery image?"
          },
          "year": {
            "type": "string",
            "description": "Year of photography (e.g. 2026)"
          },
          "related_themes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_projects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_publications": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_news": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_people": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
