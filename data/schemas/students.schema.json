{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Students Roster",
  "type": "object",
  "required": ["students"],
  "properties": {
    "students": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "role", "yearStarted", "projectFocus", "email", "joined_lab", "status"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the student (e.g. jane-doe)"
          },
          "name": {
            "type": "string",
            "description": "Full name of the student"
          },
          "role": {
            "type": "string",
            "description": "Student's role in the lab (e.g., Ph.D. Candidate, Undergraduate Researcher)"
          },
          "yearStarted": {
            "type": "string",
            "description": "Year they joined the research group"
          },
          "projectFocus": {
            "type": "string",
            "description": "Short summary of their project focus or thesis topic"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address"
          },
          "linkedin": {
            "type": "string",
            "description": "Optional LinkedIn URL"
          },
          "photo": {
            "type": "string",
            "description": "Relative path to the student's headshot"
          },
          "joined_lab": {
            "type": "string",
            "description": "Year they joined the Salguero Lab"
          },
          "status": {
            "type": "string",
            "enum": ["Current Member", "Alumni"],
            "description": "Active status of the member in the group"
          },
          "graduated_year": {
            "type": "string",
            "description": "Year of graduation or departure from the lab (if Alumnus)"
          },
          "degree": {
            "type": "string",
            "description": "Degree earned during current lab membership (if applicable)"
          },
          "degree_institution": {
            "type": "string",
            "description": "Institution granting the degree"
          },
          "degree_year": {
            "type": "string",
            "description": "Year the degree was earned"
          }
        }
      }
    }
  }
}
