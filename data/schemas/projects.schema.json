{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Projects Database",
  "type": "object",
  "required": ["projects"],
  "properties": {
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "summary", "detailedDescription", "tags"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique URL-friendly slug/identifier for the project"
          },
          "title": {
            "type": "string",
            "description": "Full title of the research project"
          },
          "status": {
            "type": "string",
            "enum": ["Planning", "Active", "Completed"],
            "description": "Current status of the project"
          },
          "summary": {
            "type": "string",
            "description": "Brief one-to-two sentence summary for preview cards"
          },
          "detailedDescription": {
            "type": "string",
            "description": "In-depth description of the project goals and results"
          },
          "tags": {
            "type": "array",
            "description": "List of thematic keywords (e.g. Synthesis, Thin Films)",
            "items": { "type": "string" }
          },
          "image": {
            "type": "string",
            "description": "Path to research graphic or image"
          },
          "funding": {
            "type": "string",
            "description": "Sponsor or agency details supporting the research"
          },
          "research_theme": {
            "type": "string",
            "description": "Primary research theme (e.g. 2D Materials, Chalcogenides, Catalysis)"
          },
          "scientific_motivation": {
            "type": "string",
            "description": "Scientific question or motivation driving this project"
          },
          "research_objectives": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Key target objectives"
          },
          "techniques": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Experimental techniques employed"
          },
          "expected_outcomes": {
            "type": "string",
            "description": "Expected scientific results"
          },
          "applications": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Applications of the research outcomes"
          },
          "timeline": {
            "type": "string",
            "description": "Project duration dates (e.g. 2024 - 2027)"
          },
          "project_leads": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Lab members leading this project"
          },
          "related_grants": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Linked grant IDs"
          },
          "related_publications": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Linked publication IDs"
          },
          "related_collaborators": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Linked collaborator IDs"
          },
          "milestones": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["year", "title"],
              "properties": {
                "year": { "type": "string" },
                "title": { "type": "string" }
              }
            }
          },
          "workflow": {
            "type": "object",
            "required": ["question", "methods", "materials", "characterization", "results", "applications"],
            "properties": {
              "question": { "type": "string" },
              "methods": { "type": "string" },
              "materials": { "type": "string" },
              "characterization": { "type": "string" },
              "results": { "type": "string" },
              "applications": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
