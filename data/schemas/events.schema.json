{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lab Events & Timeline",
  "type": "object",
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "date", "description", "type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the event"
          },
          "title": {
            "type": "string",
            "description": "Title of the event"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Event date in YYYY-MM-DD format"
          },
          "time": {
            "type": "string",
            "description": "Optional time of the event (e.g., 2:00 PM)"
          },
          "location": {
            "type": "string",
            "description": "Optional location details (e.g., Room 301, Zoom)"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the event"
          },
          "type": {
            "type": "string",
            "enum": ["Group Meeting", "Dissertation Defense", "Departmental Seminar", "Outreach", "Other"],
            "description": "Category of the event"
          }
        }
      }
    }
  }
}
