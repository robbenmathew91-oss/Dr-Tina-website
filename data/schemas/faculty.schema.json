{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Faculty Profile Schema",
  "type": "object",
  "required": [
    "name",
    "title",
    "department",
    "institution",
    "office",
    "phone",
    "email",
    "photo",
    "googleScholar",
    "orcid",
    "summary",
    "quickFacts",
    "researchVision",
    "timeline",
    "education",
    "graduateAndPostdoc",
    "leadershipAndMentorship",
    "researchInterests",
    "awards",
    "professionalService",
    "milestones"
  ],
  "properties": {
    "name": { "type": "string" },
    "title": { "type": "string" },
    "department": { "type": "string" },
    "institution": { "type": "string" },
    "office": { "type": "string" },
    "phone": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "photo": { "type": "string" },
    "googleScholar": { "type": "string" },
    "orcid": { "type": "string" },
    "biography": { "type": "string" },
    "summary": {
      "type": "array",
      "items": { "type": "string" }
    },
    "quickFacts": {
      "type": "object",
      "properties": {
        "yearsAtUGA": { "type": "string" },
        "activeResearchThemes": { "type": ["string", "number"] },
        "activeGrants": { "type": ["string", "number"] },
        "currentLabMembers": { "type": ["string", "number"] },
        "totalPublications": { "type": ["string", "number"] },
        "totalCitations": { "type": "string" },
        "hIndex": { "type": ["string", "number"] },
        "metricsDisclaimer": { "type": "string" }
      }
    },
    "researchVision": {
      "type": "object",
      "required": ["philosophy", "longTermVision", "whyItMatters", "interdisciplinaryApproach", "futureDirections"],
      "properties": {
        "philosophy": { "type": "string" },
        "longTermVision": { "type": "string" },
        "whyItMatters": { "type": "string" },
        "interdisciplinaryApproach": { "type": "string" },
        "futureDirections": { "type": "string" }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["year", "milestone", "category"],
        "properties": {
          "year": { "type": "string" },
          "milestone": { "type": "string" },
          "category": { "type": "string" },
          "details": { "type": "string" }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["degree", "institution", "year"],
        "properties": {
          "degree": { "type": "string" },
          "institution": { "type": "string" },
          "year": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "graduateAndPostdoc": {
      "type": "object",
      "required": ["doctoral", "postdoctoral", "industrial"],
      "properties": {
        "doctoral": {
          "type": "object",
          "required": ["degree", "institution", "year", "advisor", "focus", "summary"],
          "properties": {
            "degree": { "type": "string" },
            "institution": { "type": "string" },
            "year": { "type": "string" },
            "advisor": { "type": "string" },
            "focus": { "type": "string" },
            "summary": { "type": "string" },
            "nobelNotes": { "type": "string" }
          }
        },
        "postdoctoral": {
          "type": "object",
          "required": ["role", "institution", "fellowship", "summary"],
          "properties": {
            "role": { "type": "string" },
            "institution": { "type": "string" },
            "fellowship": { "type": "string" },
            "summary": { "type": "string" }
          }
        },
        "industrial": {
          "type": "object",
          "required": ["role", "organization", "focus", "summary"],
          "properties": {
            "role": { "type": "string" },
            "organization": { "type": "string" },
            "focus": { "type": "string" },
            "summary": { "type": "string" }
          }
        }
      }
    },
    "leadershipAndMentorship": {
      "type": "object",
      "required": ["roles", "mentoringPhilosophy", "trainingPrograms", "outreachAndEquity"],
      "properties": {
        "roles": { "type": "array", "items": { "type": "string" } },
        "mentoringPhilosophy": { "type": "string" },
        "trainingPrograms": { "type": "string" },
        "outreachAndEquity": { "type": "string" }
      }
    },
    "researchInterests": {
      "type": "array",
      "items": { "type": "string" }
    },
    "awards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["award", "year", "details"],
        "properties": {
          "award": { "type": "string" },
          "year": { "type": "string" },
          "details": { "type": "string" }
        }
      }
    },
    "professionalService": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "organization", "details"],
        "properties": {
          "role": { "type": "string" },
          "organization": { "type": "string" },
          "details": { "type": "string" }
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["year", "title", "description"],
        "properties": {
          "year": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
