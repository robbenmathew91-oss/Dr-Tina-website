{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alumni Roster",
  "type": "object",
  "required": ["alumni"],
  "properties": {
    "alumni": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "degree", "graduationYear", "currentPosition", "joined_lab", "status", "graduated_year", "degree_institution", "degree_year"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the alumnus"
          },
          "name": {
            "type": "string",
            "description": "Full name of the alumnus"
          },
          "degree": {
            "type": "string",
            "description": "Degree earned in the lab (e.g. Ph.D., M.S., B.S.)"
          },
          "graduationYear": {
            "type": "string",
            "description": "Year of graduation/departure from the lab"
          },
          "thesisTitle": {
            "type": "string",
            "description": "Title of their thesis or major project"
          },
          "currentPosition": {
            "type": "string",
            "description": "Their current employer, institution, and title"
          },
          "linkedin": {
            "type": "string",
            "description": "Optional LinkedIn URL"
          },
          "photo": {
            "type": "string",
            "description": "Relative path to the alumnus's headshot"
          },
          "joined_lab": {
            "type": "string",
            "description": "Year they joined the Salguero Lab"
          },
          "status": {
            "type": "string",
            "enum": ["Current Member", "Alumni"],
            "description": "Active status of the member in the group"
          },
          "graduated_year": {
            "type": "string",
            "description": "Year they graduated or departed from the lab"
          },
          "degree_institution": {
            "type": "string",
            "description": "Institution granting the degree"
          },
          "degree_year": {
            "type": "string",
            "description": "Year the degree was earned"
          },
          "researchFocus": {
            "type": "string",
            "description": "Summary of research focus or specialization"
          },
          "projectFocus": {
            "type": "string",
            "description": "Summary of project focus or thesis topic"
          },
          "description": {
            "type": "string",
            "description": "Summary description of research and accomplishments in the lab"
          }
        }
      }
    }
  }
}
