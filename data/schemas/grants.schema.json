{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grants List",
  "type": "object",
  "required": ["grants"],
  "properties": {
    "grants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "agency", "duration", "status", "principalInvestigator"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the grant"
          },
          "title": {
            "type": "string",
            "description": "Official title of the funded project"
          },
          "agency": {
            "type": "string",
            "description": "Funding agency (e.g. National Science Foundation)"
          },
          "grantNumber": {
            "type": "string",
            "description": "Official award number (optional)"
          },
          "amount": {
            "type": "string",
            "description": "Funding amount (optional)"
          },
          "duration": {
            "type": "string",
            "description": "Funding time span (e.g. 2024 - 2027)"
          },
          "status": {
            "type": "string",
            "enum": ["Active", "Completed"],
            "description": "Current status of the grant"
          },
          "principalInvestigator": {
            "type": "string",
            "description": "Name of the PI"
          },
          "award_year": {
            "type": "string",
            "description": "Start year of the grant award"
          },
          "summary": {
            "type": "string",
            "description": "Short overview of the project scope"
          },
          "scientific_impact": {
            "type": "string",
            "description": "Statement of scientific discovery enabled by this grant"
          },
          "techniques": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Experimental methods enabled by this grant"
          },
          "applications": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Applications enabled by this grant"
          },
          "related_projects": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Linked project IDs"
          },
          "related_publications": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Linked publication IDs"
          },
          "related_collaborators": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Linked collaborator IDs"
          },
          "milestones": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Key milestone updates achieved"
          },
          "logo_url": {
            "type": "string",
            "description": "URL or path to funding agency logo"
          },
          "research_theme": {
            "type": "string",
            "description": "Primary research theme (e.g. 2D Materials, Chalcogenides, Catalysis)"
          }
        }
      }
    }
  }
}
