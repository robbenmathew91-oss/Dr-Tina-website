{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "News Feed",
  "type": "object",
  "required": ["news"],
  "properties": {
    "news": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "title", "excerpt", "content"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the news item"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Date of publishing in YYYY-MM-DD format"
          },
          "title": {
            "type": "string",
            "description": "Title of the news post"
          },
          "excerpt": {
            "type": "string",
            "description": "Short description shown on preview cards"
          },
          "content": {
            "type": "string",
            "description": "Full HTML or plain text body of the news article"
          },
          "image": {
            "type": "string",
            "description": "Optional path to a thumbnail image"
          },
          "link": {
            "type": "string",
            "description": "Optional external link (e.g. to a UGA press release)"
          },
          "category": {
            "type": "string",
            "enum": [
              "Publications",
              "Awards",
              "Conferences",
              "Outreach",
              "Student News",
              "Lab Milestones",
              "Funding",
              "New Members",
              "Alumni"
            ],
            "description": "Classification category for the news post"
          },
          "featured": {
            "type": "boolean",
            "description": "Is this a featured news post?"
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Keywords list for indexing and search"
          },
          "year": {
            "type": "string",
            "description": "Year of publishing (e.g. 2026)"
          },
          "related_publications": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_projects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_themes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_grants": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_people": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
